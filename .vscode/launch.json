{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Streamlit: Run App",
            "type": "python",
            "request": "launch",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "module": "streamlit",
            "cwd": "${workspaceFolder}",
            "args": [
                "run",
                "${workspaceFolder}\\app.py",
                "--server.port",
                "8501"
            ],
            "jinja": true,
            "justMyCode": true
        }
    ]
}
