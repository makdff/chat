# API Keys for LLM Providers (Optional, can also be set in the UI settings panel)
API_KEY_GEMINI=your_gemini_api_key_here
API_KEY_GROQ=your_groq_api_key_here
API_KEY_DEEPSEEK=your_deepseek_api_key_here
API_KEY_HUGGINGFACE=your_huggingface_token_here

# Optional: Supabase Postgres connection string for persistent cloud storage.
# Use this on Streamlit Cloud via app secrets, not by committing a real value.
# Example: postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=your_supabase_postgres_connection_string_here
